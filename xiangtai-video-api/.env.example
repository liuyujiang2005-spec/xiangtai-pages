# 服务端口
PORT=3000

# JWT（生产环境务必更换）
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS 白名单（逗号分隔），生产建议只填前端域名
# CORS_ORIGIN=https://your-frontend.vercel.app,https://your-custom-domain.com

# bcrypt 强度（生产可适当调高；越高越慢）
# BCRYPT_ROUNDS=10

# SQLite 数据库文件路径（默认项目根目录 data.db）
# SQLITE_PATH=./data.db

# 上传目录与对外 URL（部署时填 CDN 或 OSS 域名）
# UPLOAD_DIR=./uploads
# UPLOAD_PUBLIC_URL=https://cdn.example.com/uploads

# 可选：S3 兼容存储（配置后上传可改为存 OSS/S3）
# S3_ENDPOINT=
# S3_BUCKET=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_REGION=
